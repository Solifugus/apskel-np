<app title="Auth Demo" version="0.1">

    <client style="style.css">

        <who type="layout" orient="horizontal">
            Signed in as: {app.identity.email} — status: {app.identity.status}
        </who>

        <signup type="register"/>
        <signin type="login"/>

        <editor type="layout" orient="vertical" table="journal" record="1">
            Private note (saving requires being logged in):
            <noteInput type="text-area" field=".entry" rows="5" placeholder="visible to any tab, writable only with a token"/>
        </editor>

    </client>

</app>
