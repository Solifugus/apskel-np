<app title="Identity Tables Are Wire-Locked" version="0.1">

    <client>

        <editor type="layout" orient="vertical" table="notes" record="1">
            <noteInput type="text-input" field=".text"/>
        </editor>

    </client>

    <data>
        <graph name="scratch">
            <users read="public">
                <notes read="users" write="users"/>
            </users>
        </graph>
    </data>

</app>
