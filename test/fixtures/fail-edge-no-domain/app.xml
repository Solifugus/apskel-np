<app title="Edge Without Domain" version="0.1">

    <client>

        <editor type="layout" orient="vertical" table="articles" record="1">
            Tags: {.tags}
        </editor>

    </client>

    <data>
        <graph name="knowledge">
            <users>
                <articles read="public" write="owner">
                    <tags read="public" write="none"/>
                </articles>
            </users>
        </graph>
    </data>

</app>
