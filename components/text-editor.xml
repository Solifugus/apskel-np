<component name="text-editor">

    <editorBox type="layout" orient="vertical">
        <titleLabel type="layout">Title</titleLabel>
        <titleInput type="text-input" field=".title" placeholder="article title"/>
        <bodyLabel type="layout">Body</bodyLabel>
        <bodyInput type="rich-text" mode="split" field=".body" rows="10" placeholder="draft here — it autosaves (markup: # heading, **bold**, *italic*, `code`, [link](url), - list)"/>
    </editorBox>

</component>
